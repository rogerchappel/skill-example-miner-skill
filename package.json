{
  "name": "skill-example-miner-skill",
  "version": "0.1.0",
  "description": "Mine completed agent runs into safe reusable skill examples.",
  "type": "module",
  "bin": {
    "skill-example-miner": "./bin/cli.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node scripts/check.js",
    "smoke": "node bin/cli.js fixtures/run-note.md",
    "lint": "npm run check",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm run test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-skill",
    "agents",
    "cli",
    "dry-run"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/skill-example-miner-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/skill-example-miner-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/skill-example-miner-skill#readme",
  "files": [
    "bin",
    "src",
    "docs",
    "fixtures",
    "examples",
    "scripts",
    "SKILL.md",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ]
}
